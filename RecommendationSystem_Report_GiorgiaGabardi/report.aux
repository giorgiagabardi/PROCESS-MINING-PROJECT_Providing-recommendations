\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Prefix length analysis (1--12). \textbf  {Left}: Decision tree F1---relatively stable around 0.85, peaking at prefix length 11 (0.882). \textbf  {Center}: Recommendation system F1---zero for most short prefixes, with the best performance at prefix length 11 ($F_{\text  {rec}}$ = 0.500). \textbf  {Right}: Number of negative predictions per prefix length---the bar chart explains the recommendation trend: only when the tree produces a meaningful number of negative predictions (prefix $\geq $ 9) can the recommendation system be evaluated and potentially succeed.}}{17}{figure.caption.9}\protected@file@percent }
\newlabel{fig:prefix-f1}{{5}{17}{Prefix length analysis (1--12). \textbf {Left}: Decision tree F1---relatively stable around 0.85, peaking at prefix length 11 (0.882). \textbf {Center}: Recommendation system F1---zero for most short prefixes, with the best performance at prefix length 11 ($F_{\text {rec}}$ = 0.500). \textbf {Right}: Number of negative predictions per prefix length---the bar chart explains the recommendation trend: only when the tree produces a meaningful number of negative predictions (prefix $\geq $ 9) can the recommendation system be evaluated and potentially succeed}{figure.caption.9}{}}
