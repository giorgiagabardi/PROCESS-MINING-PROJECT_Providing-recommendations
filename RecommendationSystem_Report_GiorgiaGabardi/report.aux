\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Recommendation evaluation results (prefix length~=~11). \textbf  {Left}: Confusion matrix for the recommendation system, where the axes represent the recommendation status (followed/not followed) and the ground-truth outcome. \textbf  {Right}: Side-by-side comparison of tree prediction metrics (blue) and recommendation evaluation metrics (green). The gap between the two sets of metrics reflects the additional difficulty of not only predicting the outcome correctly, but also generating recommendations that are actually followed and effective.}}{15}{figure.caption.5}\protected@file@percent }
\newlabel{fig:rec-evaluation}{{4}{15}{Recommendation evaluation results (prefix length~=~11). \textbf {Left}: Confusion matrix for the recommendation system, where the axes represent the recommendation status (followed/not followed) and the ground-truth outcome. \textbf {Right}: Side-by-side comparison of tree prediction metrics (blue) and recommendation evaluation metrics (green). The gap between the two sets of metrics reflects the additional difficulty of not only predicting the outcome correctly, but also generating recommendations that are actually followed and effective}{figure.caption.5}{}}
